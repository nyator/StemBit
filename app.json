{
  "expo": {
    "name": "StemBit",
    "slug": "StemBit",
    "scheme": "stembit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#101116"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "stembit",
      "runtimeVersion": "1.0.0"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#101116"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-audio",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9c8300a2-cec7-491a-b47b-54c561333c1b"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/9c8300a2-cec7-491a-b47b-54c561333c1b"
    }
  }
}
